{{define "htmlMenu"}}<div class="offcanvas offcanvas-end" tabindex="-1" id="htmlMenuOffcanvas" data-bs-scroll="false" aria-labelledby="htmlMenuOffcanvas" data-bs-backdrop="true" data-bs-keyboard="true">
        <div class="offcanvas-header d-flex align-items-center" id="menuOffcanvasHeader">
            <a href="https://app.yourplace.network/p/" class="grow cursorPointer" id="menuAvatarLink">
                <img src="/static/image/yourplace-logo.svg" id="menuAvatar" alt="avatar" crossorigin="anonymous" referrerpolicy="no-referrer">
            </a>
            <span class="grow cursorPointer">
                <button class="btn btn-primary" id="menuLoginBtn"><span class="menuLoginText">Login</span></button>
            </span>
        </div>
        <div class="offcanvas-body flex" id="menuBody">
            <a href="https://app.yourplace.network/" class="menuItemA">
                <div id="menuHome" class="menuItemDiv grow cursorPointer">🏠 Home</div>
            </a>
            <!--<a href="https://app.yourplace.network/" class="menuItemA">
                <div id="menuBrowse" class="menuItemDiv grow cursorPointer">🔍 Search</div>
            </a>-->
            <a href="/download" class="menuItemA">
                <div id="menuDownload" class="menuItemDiv grow cursorPointer">💾 Download</div>
            </a>
            <a href="https://app.yourplace.network/mentalHealth" class="menuItemA">
                <div id="menuMentalHealth" class="menuItemDiv grow cursorPointer">🧠 <span class="menuMentalText">Mental </span>Health</div>
            </a>
            <a href="https://app.yourplace.network/faq" class="menuItemA">
                <div id="menuFAQ" class="menuItemDiv grow cursorPointer">🙋 FAQ</div>
            </a>
            <a href="https://github.com/YourPlace-Network/Server/issues/new?template=bug_report.md" class="menuItemA" target="_blank">
                <div id="menuBug" class="menuItemDiv grow cursorPointer">🪲 Report Bug</div>
            </a>
            <a href="/about" class="menuItemA">
                <div id="menuabout" class="menuItemDiv grow cursorPointer">ℹ️ About</div>
            </a>
        </div>
    </div>
    <button class="btn grow" id="htmlMenu" data-bs-toggle="offcanvas" data-bs-target="#htmlMenuOffcanvas" aria-controls="offcanvasWithBothOptions">
        <span class="hamburger-icon">
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
        </span>
    </button>
{{end}}